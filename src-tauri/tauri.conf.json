{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Coffee",
  "version": "0.2.2",
  "identifier": "com.kavish.focuscoffee",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Focus Coffee",
        "width": 370,
        "height": 600,
        "alwaysOnTop": true,
        "transparent": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "android": {
      "versionCode": 1006
    }
  }
}
